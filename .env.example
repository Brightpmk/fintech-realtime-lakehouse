# Copy this file to .env and fill in real values before running docker compose.
AWS_ACCESS_KEY_ID=<change-me>
AWS_SECRET_ACCESS_KEY=<change-me>
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
PII_HASH_SALT=<generate-with: python -c "import secrets; print(secrets.token_hex(32))">
ICEBERG_CATALOG_DB_NAME=iceberg
ICEBERG_CATALOG_DB_USER=iceberg
ICEBERG_CATALOG_DB_PASSWORD=<change-me>
TRINO_USER=admin
