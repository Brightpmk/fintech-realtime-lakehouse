# ================================================================
# Copy this file to .env and fill in real values before running docker compose.
#
# Generate all secrets in one command:
#   python -c "import secrets; print(f'AWS_ACCESS_KEY_ID=admin\nAWS_SECRET_ACCESS_KEY={secrets.token_urlsafe(32)}\nAWS_REGION=us-east-1\nAWS_DEFAULT_REGION=us-east-1\nPII_HASH_SALT={secrets.token_hex(32)}\nICEBERG_CATALOG_DB_NAME=iceberg\nICEBERG_CATALOG_DB_USER=iceberg\nICEBERG_CATALOG_DB_PASSWORD={secrets.token_urlsafe(24)}\nTRINO_USER=admin')"
# ================================================================
AWS_ACCESS_KEY_ID=<change-me>
AWS_SECRET_ACCESS_KEY=<change-me>
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
PII_HASH_SALT=<change-me-generate-with-command-above>
ICEBERG_CATALOG_DB_NAME=iceberg
ICEBERG_CATALOG_DB_USER=iceberg
ICEBERG_CATALOG_DB_PASSWORD=<change-me>
TRINO_USER=admin
